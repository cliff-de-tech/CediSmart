# =============================================================================
# CediSmart API — Environment Variables
# Copy to .env and fill in actual values. NEVER commit .env to Git.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cedismart

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT / Security ---
# RS256 requires a PEM-encoded RSA key pair.
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM content (including BEGIN/END lines) below.
# Replace newlines with \n when storing in Railway env vars.
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# --- Application ---
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Termii SMS (OTP delivery) ---
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=CediSmart
